# ============================================================
# IFL Pretty-Printing — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to source control.
# ============================================================

# --- Required ---

# Main connection key used by the broadcast dashboard.
# Choose a strong random string (e.g. openssl rand -base64 32).
CONNECTION_KEY=change_me_to_a_strong_random_string

# --- Optional ---

# Additional access key for the Run It Back (RIB) section.
# If omitted, the RIB section is accessible without a second key.
IFF_ACCESS_KEY=

# start.gg API key for tournament sync.
# Obtain from https://developer.start.gg/
STARTGG_API_KEY=

# --- Database ---

# MySQL / MariaDB connection settings.
# Defaults shown below (do NOT use root with empty password in production).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ifl_user
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=tournament_handler
